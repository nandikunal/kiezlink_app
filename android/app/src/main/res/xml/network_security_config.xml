<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic for local development API server on Android emulator/physical device -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Add your development machine IP here -->
        <domain includeSubdomains="true">192.168.1.0</domain>
    </domain-config>
    
    <!-- By default, cleartext traffic is not permitted -->
    <default-config cleartextTrafficPermitted="false"/>
</network-security-config>
